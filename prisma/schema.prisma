// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model users {
  user_index       Int             @id @default(autoincrement())
  user_display     String
  user_email       String          @unique
  user_password    String
  user_permission  UserPermission  @default(unverified)
  user_restriction Boolean         @default(false)
  workspaces       workspaces[]
  refreshTokens    refresh_token[]
}

model refresh_token {
  token_index      Int       @id @default(autoincrement())
  token_owner      Int
  token            String
  token_created_at DateTime  @default(now())
  token_expired_at DateTime?

  owner users @relation(fields: [token_owner], references: [user_index])
}

model workspaces {
  workspace_index       Int         @id @default(autoincrement())
  workspace_owner       Int     
  workspace_name        String
  workspace_created_at  DateTime    @default(now())
  workspace_deleted_at  DateTime?
  agents                agents[]

  @@unique([workspace_owner, workspace_name])
  owner users @relation(fields: [workspace_owner], references: [user_index])
}

/**
 * 새 OPTiCS 에이전트를 생성했을 때 연결 코드
 */
model agents {
  agent_index             Int               @id @default(autoincrement())
  agent_ip                String
  agent_code              String            @unique
  agent_parent_workspace  Int?        
  agent_connection        ConnectionStatus  @default(unlinked)
  agent_status            AgentStatus       @default(waiting)
  agent_created_at        DateTime          @default(now())
  agent_deleted_at        DateTime?
  agent_last_online       DateTime          @default(now())

  parent workspaces? @relation(fields: [agent_parent_workspace], references: [workspace_index])
}

enum UserPermission {
  unverified
  verified
  moderator
  administrator
}

enum ConnectionStatus {
  unlinked
  requested
  linked
}

enum AgentStatus {
  waiting
  online
  offline
  restarting
  failed
}
