// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model users {
  user_index       Int             @id @default(autoincrement())
  user_display     String
  user_email       String          @unique
  user_password    String
  user_permission  UserPermission  @default(unverified)
  user_restriction Boolean         @default(false)
  workspaces       workspaces[]
  refreshTokens    refresh_token[]
}

model refresh_token {
  token_index      Int       @id @default(autoincrement())
  token_owner      Int
  token            String
  token_created_at DateTime  @default(now())
  token_expired_at DateTime?

  owner users @relation(fields: [token_owner], references: [user_index])
}

model workspaces {
  workspace_index            Int                 @id @default(autoincrement())
  workspace_owner            Int
  workspace_name             String
  workspace_subdomain        String?
  workspace_subdomain_active Boolean             @default(false)
  workspace_dns_record_id    String?
  workspace_created_at       DateTime            @default(now())
  workspace_deleted_at       DateTime?
  agents                     agents[]
  services                   services[]
  service_endpoints          service_endpoints[]
  owner                      users               @relation(fields: [workspace_owner], references: [user_index])

  @@unique([workspace_owner, workspace_name])
}

/**
 * 새 OPTiCS 에이전트를 생성했을 때 연결 코드
 */
model agents {
  agent_index            Int              @id @default(autoincrement())
  agent_ip               String
  agent_code             String           @unique
  agent_uuid             String           @unique @default(uuid())
  agent_name             String
  agent_parent_workspace Int?
  agent_connection       ConnectionStatus @default(unlinked)
  agent_status           AgentStatus      @default(waiting)
  agent_created_at       DateTime         @default(now())
  agent_deleted_at       DateTime?
  agent_last_online      DateTime         @default(now())
  services               services[]

  parent workspaces? @relation(fields: [agent_parent_workspace], references: [workspace_index])
}

model services {
  service_index            Int                  @id @default(autoincrement())
  service_name             String
  service_port             Int
  service_container_port   Int?
  service_host_port        Int?
  service_port_mappings    Json?
  service_source_url       String               @db.LongText
  service_subdomain        String?
  service_root_directory   String?
  service_env              Json?
  service_parent_workspace Int
  service_parent_agent     Int
  service_status           ServiceStatus        @default(waiting)
  service_version          String
  service_deploy_preset    DeployPreset         @default(dockerfile)
  service_created_at       DateTime             @default(now())
  service_deleted_at       DateTime?
  components               service_components[]
  endpoints                service_endpoints[]

  workspace workspaces @relation(fields: [service_parent_workspace], references: [workspace_index])
  agent     agents     @relation(fields: [service_parent_agent], references: [agent_index])

  @@unique([service_parent_workspace, service_subdomain, service_deleted_at])
}

model service_components {
  component_index          Int                    @id @default(autoincrement())
  component_parent_service Int
  component_name           String
  component_container_name String?
  component_status         ServiceComponentStatus @default(waiting)
  component_health         String?
  component_exit_code      Int?
  component_created_at     DateTime               @default(now())
  component_updated_at     DateTime               @updatedAt
  component_deleted_at     DateTime?

  service services @relation(fields: [component_parent_service], references: [service_index])

  @@unique([component_parent_service, component_name])
}

model service_endpoints {
  endpoint_index            Int       @id @default(autoincrement())
  endpoint_parent_workspace Int
  endpoint_parent_service   Int
  endpoint_component_name   String?
  endpoint_subdomain        String?
  endpoint_host_port        Int
  endpoint_container_port   Int
  endpoint_created_at       DateTime  @default(now())
  endpoint_updated_at       DateTime  @updatedAt
  endpoint_deleted_at       DateTime?

  workspace workspaces @relation(fields: [endpoint_parent_workspace], references: [workspace_index])
  service   services   @relation(fields: [endpoint_parent_service], references: [service_index])

  @@unique([endpoint_parent_workspace, endpoint_subdomain, endpoint_deleted_at])
}

enum UserPermission {
  unverified
  verified
  moderator
  administratorServices
}

enum ConnectionStatus {
  unlinked
  requested
  linked
}

enum AgentStatus {
  waiting
  online
  offline
  restarting
  failed
}

enum ServiceStatus {
  waiting
  building
  starting
  running
  stopped
  failed
  removed
}

enum ServiceComponentStatus {
  waiting
  building
  starting
  running
  stopped
  failed
  removed
  restarting
}

enum DeployPreset {
  dockerfile
  compose

  preset_nestjs
}
