// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model users {
  user_index       Int             @id @default(autoincrement())
  user_display     String
  user_email       String
  user_password    String
  user_permission  UserPermission  @default(unverified)
  user_restriction Boolean         @default(false)
  containers       containers[]
  refreshTokens    refresh_token[]
}

model refresh_token {
  token_index      Int       @id @default(autoincrement())
  token_owner      Int
  token            String
  token_created_at DateTime  @default(now())
  token_expired_at DateTime?

  owner users @relation(fields: [token_owner], references: [user_index])
}

/**
 * Connection Code로 중앙 서버 컨테이너와 연결이 성립된 서버
 */
model containers {
  container_index       Int        @id @default(autoincrement())
  container_owner       Int
  container_name        String
  agent_token           String?
  container_status      HostStatus @default(unlinked)
  container_last_online DateTime?
  container_created_at  DateTime   @default(now())
  container_deleted_at  DateTime?

  owner users @relation(fields: [container_owner], references: [user_index])
}

/**
 * 새 OPTiCS 에이전트를 생성했을 때 연결 코드
 */
model agents {
  agent_index       Int      @id @default(autoincrement())
  agent_ip          String
  agent_token       String
  agent_established Boolean  @default(false)
  agent_created_at  DateTime @default(now())
  agent_deleted_at  DateTime?
}

enum UserPermission {
  unverified
  verified
  moderator
  administrator
}

enum HostStatus {
  unlinked
  linked
  offline
}
